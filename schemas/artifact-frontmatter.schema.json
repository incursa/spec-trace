{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "artifact-frontmatter.schema.json",
  "title": "Artifact Front Matter",
  "description": "Strict reference schema for file-level YAML front matter used by the Markdown templates in this package. See artifact-id-policy.json for the shared identifier policy.",
  "$comment": "The shared identifier policy lives in artifact-id-policy.json.",
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "stringArray": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/nonEmptyString"
      },
      "minItems": 1,
      "uniqueItems": true
    }
  },
  "oneOf": [
    {
      "title": "Specification Front Matter",
      "type": "object",
      "required": [
        "artifact_id",
        "artifact_type",
        "title",
        "domain",
        "capability",
        "status",
        "owner"
      ],
      "properties": {
        "artifact_id": {
          "type": "string",
          "pattern": "^SPEC-[A-Z0-9]+(?:-[A-Z0-9]+)*-\\d{4,}$"
        },
        "artifact_type": {
          "const": "specification"
        },
        "title": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "domain": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "capability": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "status": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "owner": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "tags": {
          "$ref": "#/$defs/stringArray"
        },
        "related_artifacts": {
          "$ref": "#/$defs/stringArray"
        }
      },
      "additionalProperties": false
    },
    {
      "title": "Architecture Front Matter",
      "type": "object",
      "required": [
        "artifact_id",
        "artifact_type",
        "title",
        "domain",
        "status",
        "owner",
        "satisfies"
      ],
      "properties": {
        "artifact_id": {
          "type": "string",
          "pattern": "^ARC-[A-Z0-9]+(?:-[A-Z0-9]+)*-\\d{4,}$"
        },
        "artifact_type": {
          "const": "architecture"
        },
        "title": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "domain": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "status": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "owner": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "satisfies": {
          "$ref": "#/$defs/stringArray"
        },
        "related_artifacts": {
          "$ref": "#/$defs/stringArray"
        }
      },
      "additionalProperties": false
    },
    {
      "title": "Work Item Front Matter",
      "type": "object",
      "required": [
        "artifact_id",
        "artifact_type",
        "title",
        "domain",
        "status",
        "owner",
        "addresses",
        "design_links",
        "verification_links"
      ],
      "properties": {
        "artifact_id": {
          "type": "string",
          "pattern": "^WI-[A-Z0-9]+(?:-[A-Z0-9]+)*-\\d{4,}$"
        },
        "artifact_type": {
          "const": "work_item"
        },
        "title": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "domain": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "status": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "owner": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "addresses": {
          "$ref": "#/$defs/stringArray"
        },
        "design_links": {
          "$ref": "#/$defs/stringArray"
        },
        "verification_links": {
          "$ref": "#/$defs/stringArray"
        },
        "related_artifacts": {
          "$ref": "#/$defs/stringArray"
        }
      },
      "additionalProperties": false
    },
    {
      "title": "Verification Front Matter",
      "type": "object",
      "required": [
        "artifact_id",
        "artifact_type",
        "title",
        "domain",
        "status",
        "owner",
        "verifies"
      ],
      "properties": {
        "artifact_id": {
          "type": "string",
          "pattern": "^VER-[A-Z0-9]+(?:-[A-Z0-9]+)*-\\d{4,}$"
        },
        "artifact_type": {
          "const": "verification"
        },
        "title": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "domain": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "status": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "owner": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "verifies": {
          "$ref": "#/$defs/stringArray"
        },
        "related_artifacts": {
          "$ref": "#/$defs/stringArray"
        }
      },
      "additionalProperties": false
    }
  ]
}

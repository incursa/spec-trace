{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "requirement-trace-fields.schema.json",
  "title": "Requirement Trace Fields",
  "description": "Reference schema for the canonical trace labels used inside requirement sections in specification documents.",
  "type": "object",
  "properties": {
    "Derived From": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "Satisfied By": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "Implemented By": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "Verified By": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "Supersedes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "Related": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": false
}
